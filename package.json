{
  "name": "mission-control",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:android": "cross-env VITE_BASE=./ vite build",
    "test": "vitest",
    "test:watch": "vitest",
    "android:copy": "npm run build:android && cap copy android",
    "android:sync": "npm run build:android && cap sync android",
    "android:open": "cap open android",
    "android:run": "npm run build:android && cap run android",
    "android:apk:debug": "npm run android:sync && cd android && gradlew.bat assembleDebug",
    "android:apk:release": "npm run android:sync && cd android && gradlew.bat assembleRelease",
    "build:firebase": "cross-env VITE_BASE=/ vite build",
    "deploy:functions": "firebase deploy --only functions",
    "deploy:firebase": "npm run build:firebase && firebase deploy",
    "lint": "eslint .",
    "preview": "vite preview",
    "deploy": "npm run build"
  },
  "dependencies": {
    "@capacitor/android": "^8.2.0",
    "@capacitor/app": "^8.0.1",
    "@capacitor/cli": "^8.2.0",
    "@capacitor/core": "^8.2.0",
    "@capacitor/push-notifications": "^8.0.2",
    "firebase": "^12.6.0",
    "lucide-react": "^0.555.0",
    "pdfjs-dist": "^5.5.207",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.13.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "autoprefixer": "^10.4.22",
    "cross-env": "^10.1.0",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17",
    "vite": "^7.2.4",
    "vitest": "^3.2.4"
  }
}
