rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ═══════════════════════════════════════════════════════════
    //  HELPER FUNCTIONS
    // ═══════════════════════════════════════════════════════════

    // Platform Admin: stored in users/{uid}.platformRole
    function isPlatformAdmin() {
      return request.auth != null &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid))
          .data.get('platformRole', '').matches('\\s*platformAdmin\\s*');
    }

    function membershipPath(teamId) {
      return /databases/$(database)/documents/memberships/$(request.auth.uid + '_' + teamId);
    }

    function membershipExists(teamId) {
      return exists(membershipPath(teamId));
    }

    function membershipDoc(teamId) {
      return get(membershipPath(teamId));
    }

    function myMembershipId(teamId) {
      return request.auth.uid + '_' + teamId;
    }

    function isActiveMember(teamId) {
      return request.auth != null && (
        isPlatformAdmin() || (
          membershipExists(teamId) &&
          membershipDoc(teamId).data.status == 'active'
        )
      );
    }

    function myRole(teamId) {
      return membershipDoc(teamId).data.role;
    }

    function isTeamAdmin(teamId) {
      return isPlatformAdmin() || (
        isActiveMember(teamId) &&
        myRole(teamId) in ['teamAdmin', 'facultyAdvisor']
      );
    }

    function isLeaderOrAbove(teamId) {
      return isPlatformAdmin() || (
        isActiveMember(teamId) &&
        myRole(teamId) in ['teamAdmin', 'facultyAdvisor', 'leader']
      );
    }

    function isRookieOrAbove(teamId) {
      return isPlatformAdmin() || (
        isActiveMember(teamId) &&
        myRole(teamId) in ['teamAdmin', 'leader', 'senior', 'junior', 'rookie']
      );
    }

    function canPostOwnWeeklyStatus(teamId) {
      return request.auth != null && (
        isPlatformAdmin() || (
          membershipExists(teamId) &&
          membershipDoc(teamId).data.status in ['active', 'pending']
        )
      );
    }

    function isAreaLeaderCanStrikeTarget(teamId, targetCategoryId) {
      return request.auth != null
        && membershipExists(teamId)
        && membershipDoc(teamId).data.status == 'active'
        && membershipDoc(teamId).data.role == 'leader'
        && membershipDoc(teamId).data.get('categoryId', '') != ''
        && targetCategoryId == membershipDoc(teamId).data.categoryId;
    }

    function isLeaderCanEditMerit(teamId, meritCategoryId) {
      return isLeaderOrAbove(teamId)
        && membershipDoc(teamId).data.role == 'leader'
        && meritCategoryId != null
        && meritCategoryId == membershipDoc(teamId).data.get('categoryId', null);
    }

    function isLeaderOrAboveInTeamList(teamIds) {
      return isPlatformAdmin() || (
        (teamIds.size() > 0 && isLeaderOrAbove(teamIds[0])) ||
        (teamIds.size() > 1 && isLeaderOrAbove(teamIds[1])) ||
        (teamIds.size() > 2 && isLeaderOrAbove(teamIds[2])) ||
        (teamIds.size() > 3 && isLeaderOrAbove(teamIds[3])) ||
        (teamIds.size() > 4 && isLeaderOrAbove(teamIds[4])) ||
        (teamIds.size() > 5 && isLeaderOrAbove(teamIds[5])) ||
        (teamIds.size() > 6 && isLeaderOrAbove(teamIds[6])) ||
        (teamIds.size() > 7 && isLeaderOrAbove(teamIds[7])) ||
        (teamIds.size() > 8 && isLeaderOrAbove(teamIds[8])) ||
        (teamIds.size() > 9 && isLeaderOrAbove(teamIds[9]))
      );
    }

    function channelDocPath(channelId) {
      return /databases/$(database)/documents/crossTeamChannels/$(channelId);
    }

    function channelTeamPath(channelId, teamId) {
      return /databases/$(database)/documents/crossTeamChannelTeams/$(channelId + '_' + teamId);
    }

    function channelExists(channelId) {
      return exists(channelDocPath(channelId));
    }

    function channelDoc(channelId) {
      return get(channelDocPath(channelId));
    }

    function channelTeamExists(channelId, teamId) {
      return exists(channelTeamPath(channelId, teamId));
    }

    function channelTeamDoc(channelId, teamId) {
      return get(channelTeamPath(channelId, teamId));
    }

    match /users/{userId} {
      allow read: if request.auth != null &&
        (request.auth.uid == userId || isPlatformAdmin());
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if (
          request.auth != null &&
          request.auth.uid == userId &&
          !('platformRole' in request.resource.data.diff(resource.data).affectedKeys())
        ) || isPlatformAdmin();
      allow delete: if isPlatformAdmin();
    }

    match /teams/{teamId} {
      allow read: if request.auth != null;
      allow create: if isPlatformAdmin();
      allow update: if isTeamAdmin(teamId);
      allow delete: if isPlatformAdmin();
    }

    match /memberships/{membershipId} {
      allow read: if request.auth != null && (
        isPlatformAdmin() ||
        resource.data.userId == request.auth.uid ||
        isActiveMember(resource.data.teamId)
      );

      allow create: if request.auth != null && (
        isPlatformAdmin() ||
        request.resource.data.userId == request.auth.uid
      );

      // Profile fields: only platform admin and the member can edit (displayName, bio, etc.)
      // Team admins: only status, role, categoryId, strikes (approve join, assign role/area, strikes)
      // Area leaders: only strikes, status for members in their area
      allow update: if (request.auth != null && (
          resource.data.userId == request.auth.uid ||
          membershipId == request.auth.uid + '_' + resource.data.teamId
        ))
        || isPlatformAdmin()
        || (isTeamAdmin(resource.data.teamId) && (
            request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status']) ||
            request.resource.data.diff(resource.data).affectedKeys().hasOnly(['role']) ||
            request.resource.data.diff(resource.data).affectedKeys().hasOnly(['categoryId']) ||
            request.resource.data.diff(resource.data).affectedKeys().hasOnly(['strikes']) ||
            request.resource.data.diff(resource.data).affectedKeys().hasOnly(['strikes', 'status']) ||
            request.resource.data.diff(resource.data).affectedKeys().hasOnly(['strikes', 'strikeHistory']) ||
            request.resource.data.diff(resource.data).affectedKeys().hasOnly(['strikes', 'status', 'strikeHistory'])
          ))
        || (isAreaLeaderCanStrikeTarget(resource.data.teamId, resource.data.get('categoryId', null))
            && (
            request.resource.data.diff(resource.data).affectedKeys().hasOnly(['strikes', 'status']) ||
            request.resource.data.diff(resource.data).affectedKeys().hasOnly(['strikes', 'strikeHistory']) ||
            request.resource.data.diff(resource.data).affectedKeys().hasOnly(['strikes', 'status', 'strikeHistory'])
            ));

      allow delete: if isPlatformAdmin() ||
        isTeamAdmin(resource.data.teamId) ||
        (request.auth != null && resource.data.userId == request.auth.uid);
    }

    match /categories/{categoryId} {
      allow read: if isActiveMember(resource.data.teamId);
      allow create: if isTeamAdmin(request.resource.data.teamId);
      allow update: if isTeamAdmin(resource.data.teamId);
      allow delete: if isTeamAdmin(resource.data.teamId);
    }

    match /hrSuggestions/{suggestionId} {
      allow read: if request.auth != null && isActiveMember(resource.data.teamId);
      allow create: if request.auth != null &&
        membershipExists(request.resource.data.teamId) &&
        membershipDoc(request.resource.data.teamId).data.status == 'active';
      allow update: if isTeamAdmin(resource.data.teamId);
      allow delete: if false;
    }

    match /hrComplaints/{complaintId} {
      allow read: if request.auth != null && isTeamAdmin(resource.data.teamId);
      allow create: if request.auth != null &&
        membershipExists(request.resource.data.teamId) &&
        membershipDoc(request.resource.data.teamId).data.status == 'active';
      allow update: if false;
      allow delete: if isPlatformAdmin() ||
        (
          channelExists(resource.data.channelId) &&
          isLeaderOrAbove(channelDoc(resource.data.channelId).data.createdByTeamId)
        );
    }

    match /skillProposals/{proposalId} {
      allow read: if request.auth != null && isActiveMember(resource.data.teamId);
      allow create: if request.auth != null &&
        membershipExists(request.resource.data.teamId) &&
        membershipDoc(request.resource.data.teamId).data.status == 'active' &&
        request.resource.data.proposedByMembershipId == request.auth.uid + '_' + request.resource.data.teamId;
      allow update: if isTeamAdmin(resource.data.teamId);
      allow delete: if false;
    }

    match /merits/{meritId} {
      allow read: if isActiveMember(resource.data.teamId);
      allow create: if isTeamAdmin(request.resource.data.teamId) ||
        (isLeaderOrAbove(request.resource.data.teamId) &&
         request.resource.data.categoryId != null &&
         request.resource.data.categoryId == membershipDoc(request.resource.data.teamId).data.categoryId);
      allow update: if isTeamAdmin(resource.data.teamId) ||
        isLeaderCanEditMerit(resource.data.teamId, resource.data.get('categoryId', null));
      allow delete: if isTeamAdmin(resource.data.teamId) ||
        isLeaderCanEditMerit(resource.data.teamId, resource.data.get('categoryId', null));
    }

    match /meritEvents/{eventId} {
      // Allow read when doc doesn't exist (tx.get in profile-save) or when user is active member
      allow read: if resource == null || isActiveMember(resource.data.teamId);
      allow create: if isLeaderOrAbove(request.resource.data.teamId) ||
        (request.resource.data.autoAward == true &&
         request.resource.data.membershipId != null &&
         request.resource.data.teamId != null &&
         request.resource.data.get('awardedByUserId', '') == request.auth.uid &&
         (request.resource.data.membershipId == request.auth.uid + '_' + request.resource.data.teamId ||
          (exists(/databases/$(database)/documents/memberships/$(request.resource.data.membershipId)) &&
           get(/databases/$(database)/documents/memberships/$(request.resource.data.membershipId)).data.get('userId', '') == request.auth.uid)));
      allow update: if isPlatformAdmin() ||
        (isActiveMember(resource.data.teamId) &&
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['points']) &&
         resource.data.points == 5 &&
         request.resource.data.points == 25);
      allow delete: if isPlatformAdmin() || isLeaderOrAbove(resource.data.teamId);
    }

    match /migrations/{migrationId} {
      allow read, write: if request.auth != null;
    }

    match /profileCompleteLocks/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    match /modules/{moduleId} {
      allow read: if isRookieOrAbove(resource.data.teamId);
      allow create: if isTeamAdmin(request.resource.data.teamId);
      allow update: if isTeamAdmin(resource.data.teamId);
      allow delete: if isTeamAdmin(resource.data.teamId);
    }

    match /moduleAttempts/{attemptId} {
      allow read: if request.auth != null && (
        resource.data.userId == request.auth.uid ||
        isTeamAdmin(resource.data.teamId)
      );
      allow create: if request.auth != null &&
        isRookieOrAbove(request.resource.data.teamId) &&
        request.resource.data.userId == request.auth.uid;
      // Team admins may approve: only status, completedAt, approvedBy, approvedAt
      allow update: if isTeamAdmin(resource.data.teamId) &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'completedAt', 'approvedBy', 'approvedAt']);
      allow delete: if false;
    }

    match /academyBooks/{bookId} {
      allow read: if isRookieOrAbove(resource.data.teamId) && (
        resource.data.get('categoryId', null) == null ||
        isTeamAdmin(resource.data.teamId) ||
        membershipDoc(resource.data.teamId).data.get('categoryId', null) == resource.data.get('categoryId', null)
      );
      allow create: if isLeaderOrAbove(request.resource.data.teamId);
      allow update: if isLeaderOrAbove(resource.data.teamId);
      allow delete: if isLeaderOrAbove(resource.data.teamId);
    }

    match /academyBookProgress/{progressId} {
      allow read: if request.auth != null && (
        resource.data.userId == request.auth.uid ||
        isTeamAdmin(resource.data.teamId)
      );
      allow create: if request.auth != null &&
        isRookieOrAbove(request.resource.data.teamId) &&
        request.resource.data.userId == request.auth.uid &&
        request.resource.data.membershipId == request.auth.uid + '_' + request.resource.data.teamId;
      allow update: if request.auth != null &&
        resource.data.userId == request.auth.uid &&
        request.resource.data.userId == request.auth.uid &&
        request.resource.data.membershipId == resource.data.membershipId &&
        request.resource.data.teamId == resource.data.teamId &&
        request.resource.data.bookId == resource.data.bookId;
      allow delete: if false;
    }

    // Tasks: support assigneeMembershipIds[] (multi-assignee) and legacy assigneeMembershipId
    function isTaskAssignee(teamId) {
      return resource.data.get('assigneeMembershipIds', []).hasAny([request.auth.uid + '_' + teamId]) ||
             resource.data.get('assigneeMembershipId', '') == request.auth.uid + '_' + teamId;
    }
    function isTaskAssigner() {
      return resource.data.get('assignedByMembershipId', '') != '' &&
             exists(/databases/$(database)/documents/memberships/$(resource.data.assignedByMembershipId)) &&
             get(/databases/$(database)/documents/memberships/$(resource.data.assignedByMembershipId)).data.userId == request.auth.uid;
    }
    function taskMembershipId(teamId) {
      return request.auth.uid + '_' + teamId;
    }
    function isTaskAssigneeWorkflowUpdate(teamId) {
      return (
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'requestedReviewAt']) &&
        (
          (
            resource.data.status == 'pending' &&
            request.resource.data.status == 'pending_review' &&
            request.resource.data.requestedReviewAt != null
          ) ||
          (
            resource.data.status == 'pending_review' &&
            request.resource.data.status == 'pending' &&
            request.resource.data.requestedReviewAt == null
          )
        )
      ) || (
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['blocked', 'blockedReason', 'blockedAt']) &&
        (
          (
            resource.data.get('blocked', false) == false &&
            resource.data.status == 'pending' &&
            request.resource.data.blocked == true &&
            request.resource.data.blockedAt != null
          ) ||
          (
            resource.data.get('blocked', false) == true &&
            request.resource.data.blocked == false &&
            request.resource.data.blockedReason == null &&
            request.resource.data.blockedAt == null
          )
        )
      );
    }
    function isTaskAssignerWorkflowUpdate(teamId) {
      return (
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['knowledgeAreaIds'])
      ) || (
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['blocked', 'blockedReason', 'blockedAt']) &&
        resource.data.get('blocked', false) == true &&
        request.resource.data.blocked == false &&
        request.resource.data.blockedReason == null &&
        request.resource.data.blockedAt == null
      ) || (
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'grade', 'acceptedAt', 'completedAt', 'gradedByMembershipId']) &&
        resource.data.status == 'pending_review' &&
        request.resource.data.status == 'completed' &&
        request.resource.data.grade in ['ok', 'good', 'excellent', 'perfect'] &&
        request.resource.data.acceptedAt != null &&
        request.resource.data.completedAt != null &&
        request.resource.data.gradedByMembershipId == taskMembershipId(teamId)
      ) || (
        request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'status',
          'requestedReviewAt',
          'reviewRejectedAt',
          'reviewRejectedByMembershipId',
          'reviewFeedback',
          'acceptedAt',
          'grade',
          'completedAt',
          'gradedByMembershipId'
        ]) &&
        resource.data.status == 'pending_review' &&
        request.resource.data.status == 'pending' &&
        request.resource.data.requestedReviewAt == null &&
        request.resource.data.reviewRejectedAt != null &&
        request.resource.data.reviewRejectedByMembershipId == taskMembershipId(teamId) &&
        request.resource.data.acceptedAt == null &&
        request.resource.data.grade == null &&
        request.resource.data.completedAt == null &&
        request.resource.data.gradedByMembershipId == null
      );
    }
    match /tasks/{taskId} {
      allow read: if isActiveMember(resource.data.teamId);
      allow create: if isLeaderOrAbove(request.resource.data.teamId);
      allow update: if isActiveMember(resource.data.teamId) && (
        isLeaderOrAbove(resource.data.teamId) ||
        (isTaskAssignee(resource.data.teamId) && isTaskAssigneeWorkflowUpdate(resource.data.teamId)) ||
        (isTaskAssigner() && isTaskAssignerWorkflowUpdate(resource.data.teamId))
      );
      allow delete: if isActiveMember(resource.data.teamId) && (
        isLeaderOrAbove(resource.data.teamId) ||
        isTaskAssigner()
      );
    }

    match /teamEvents/{eventId} {
      allow read: if isActiveMember(resource.data.teamId);
      allow create: if isLeaderOrAbove(request.resource.data.teamId);
      allow update: if isLeaderOrAbove(resource.data.teamId);
      allow delete: if isLeaderOrAbove(resource.data.teamId);
    }

    match /teamSessions/{sessionId} {
      allow read: if isActiveMember(resource.data.teamId);
      allow create: if isLeaderOrAbove(request.resource.data.teamId);
      allow update: if isLeaderOrAbove(resource.data.teamId);
      allow delete: if isLeaderOrAbove(resource.data.teamId);
    }
    match /teamSessions/{sessionId}/attendance/{attendanceId} {
      allow read: if isActiveMember(get(/databases/$(database)/documents/teamSessions/$(sessionId)).data.teamId);
      allow create, update: if isLeaderOrAbove(get(/databases/$(database)/documents/teamSessions/$(sessionId)).data.teamId);
      allow delete: if false;
    }

    match /teamSwots/{swotId} {
      allow read: if isActiveMember(resource.data.teamId);
      allow create: if isLeaderOrAbove(request.resource.data.teamId);
      allow update: if isLeaderOrAbove(resource.data.teamId);
      allow delete: if isLeaderOrAbove(resource.data.teamId);
    }

    match /teamEisenhowers/{entryId} {
      allow read: if isActiveMember(resource.data.teamId);
      allow create: if isLeaderOrAbove(request.resource.data.teamId);
      allow update: if isLeaderOrAbove(resource.data.teamId);
      allow delete: if isLeaderOrAbove(resource.data.teamId);
    }

    match /teamPughs/{entryId} {
      allow read: if isActiveMember(resource.data.teamId);
      allow create: if isLeaderOrAbove(request.resource.data.teamId);
      allow update: if isLeaderOrAbove(resource.data.teamId);
      allow delete: if isLeaderOrAbove(resource.data.teamId);
    }

    match /teamBoards/{boardId} {
      allow read: if isActiveMember(resource.data.teamId);
      allow create: if isLeaderOrAbove(request.resource.data.teamId);
      allow update: if isLeaderOrAbove(resource.data.teamId);
      allow delete: if isTeamAdmin(resource.data.teamId);
    }

    match /teamAvailabilityPolls/{pollId} {
      allow read: if isActiveMember(resource.data.teamId);
      allow create: if isLeaderOrAbove(request.resource.data.teamId);
      allow update: if isLeaderOrAbove(resource.data.teamId) ||
        (
          request.auth != null &&
          isActiveMember(resource.data.teamId) &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['responses', 'lastEditedAt', 'lastEditedBy', 'lastEditedByUserId']) &&
          request.resource.data.responses.diff(resource.data.responses).affectedKeys().hasOnly([myMembershipId(resource.data.teamId)]) &&
          request.resource.data.lastEditedByUserId == request.auth.uid
        );
      allow delete: if isLeaderOrAbove(resource.data.teamId);
    }

    match /posts/{postId} {
      allow read: if isRookieOrAbove(resource.data.teamId);
      allow create: if isRookieOrAbove(request.resource.data.teamId) &&
        request.resource.data.authorId == request.auth.uid;
      allow update: if false;
      allow delete: if isTeamAdmin(resource.data.teamId) ||
        (request.auth != null && resource.data.authorId == request.auth.uid);
    }

    match /comments/{commentId} {
      allow read: if isRookieOrAbove(resource.data.teamId);
      allow create: if isRookieOrAbove(request.resource.data.teamId) &&
        request.resource.data.authorId == request.auth.uid;
      allow update: if false;
      allow delete: if isTeamAdmin(resource.data.teamId) ||
        (request.auth != null && resource.data.authorId == request.auth.uid);
    }

    match /postReactions/{reactionId} {
      allow read: if isRookieOrAbove(resource.data.teamId);
      allow create: if isRookieOrAbove(request.resource.data.teamId) &&
        request.auth != null &&
        request.resource.data.userId == request.auth.uid;
      allow update: if isRookieOrAbove(resource.data.teamId) &&
        request.auth != null &&
        resource.data.userId == request.auth.uid &&
        request.resource.data.userId == request.auth.uid &&
        request.resource.data.teamId == resource.data.teamId &&
        request.resource.data.postId == resource.data.postId;
      allow delete: if isRookieOrAbove(resource.data.teamId) &&
        request.auth != null &&
        resource.data.userId == request.auth.uid;
    }

    match /teamMeetings/{meetingId} {
      allow read: if isActiveMember(resource.data.teamId);
      allow create: if isLeaderOrAbove(request.resource.data.teamId);
      allow update: if isLeaderOrAbove(resource.data.teamId);
      allow delete: if isTeamAdmin(resource.data.teamId);
    }

    match /teamGoals/{goalId} {
      allow read: if isActiveMember(resource.data.teamId);
      allow create: if isLeaderOrAbove(request.resource.data.teamId);
      allow update: if isLeaderOrAbove(resource.data.teamId);
      allow delete: if isTeamAdmin(resource.data.teamId);
    }

    match /weeklyStatuses/{statusId} {
      // Allow read when doc doesn't exist (tx.get in weekly-save) or when user has access
      allow read: if resource == null ||
        canPostOwnWeeklyStatus(resource.data.teamId) ||
        (request.auth != null && resource.data.userId == request.auth.uid) ||
        (request.auth != null && resource.data.membershipId != null &&
         exists(/databases/$(database)/documents/memberships/$(resource.data.membershipId)) &&
         get(/databases/$(database)/documents/memberships/$(resource.data.membershipId)).data.userId == request.auth.uid);
      allow create: if request.auth != null && (
        isPlatformAdmin() ||
        isTeamAdmin(request.resource.data.teamId) ||
        isLeaderOrAbove(request.resource.data.teamId) ||
        (exists(/databases/$(database)/documents/memberships/$(request.resource.data.membershipId)) &&
         get(/databases/$(database)/documents/memberships/$(request.resource.data.membershipId)).data.userId == request.auth.uid &&
         get(/databases/$(database)/documents/memberships/$(request.resource.data.membershipId)).data.teamId == request.resource.data.teamId &&
         get(/databases/$(database)/documents/memberships/$(request.resource.data.membershipId)).data.status in ['active', 'pending'])
      );
      allow update: if request.auth != null && (
        isPlatformAdmin() ||
        isTeamAdmin(resource.data.teamId) ||
        isLeaderOrAbove(resource.data.teamId) ||
        (exists(/databases/$(database)/documents/memberships/$(resource.data.membershipId)) &&
         get(/databases/$(database)/documents/memberships/$(resource.data.membershipId)).data.userId == request.auth.uid &&
         get(/databases/$(database)/documents/memberships/$(resource.data.membershipId)).data.teamId == resource.data.teamId &&
         get(/databases/$(database)/documents/memberships/$(resource.data.membershipId)).data.status in ['active', 'pending'])
      );
      allow delete: if isTeamAdmin(resource.data.teamId);
    }

    match /teamFundingAccounts/{accountId} {
      allow read: if isActiveMember(resource.data.teamId);
      allow create: if isLeaderOrAbove(request.resource.data.teamId);
      allow update: if isLeaderOrAbove(resource.data.teamId);
      allow delete: if isLeaderOrAbove(resource.data.teamId);
    }

    match /teamFundingEntries/{entryId} {
      allow read: if isActiveMember(resource.data.teamId);
      allow create: if isLeaderOrAbove(request.resource.data.teamId);
      allow update: if false;
      allow delete: if isLeaderOrAbove(resource.data.teamId);
    }

    match /teamInventoryItems/{itemId} {
      allow read: if isActiveMember(resource.data.teamId);
      allow create: if isTeamAdmin(request.resource.data.teamId) ||
        (isLeaderOrAbove(request.resource.data.teamId) &&
         request.resource.data.categoryId != null &&
         request.resource.data.categoryId == membershipDoc(request.resource.data.teamId).data.categoryId);
      allow update: if isTeamAdmin(resource.data.teamId) ||
        isLeaderCanEditMerit(resource.data.teamId, resource.data.get('categoryId', null));
      allow delete: if isTeamAdmin(resource.data.teamId) ||
        isLeaderCanEditMerit(resource.data.teamId, resource.data.get('categoryId', null));
    }

    match /teamInventoryLoans/{loanId} {
      allow read: if isActiveMember(resource.data.teamId);
      allow create: if isLeaderOrAbove(request.resource.data.teamId);
      allow update: if isLeaderOrAbove(resource.data.teamId);
      allow delete: if isLeaderOrAbove(resource.data.teamId);
    }

    match /crossTeamChannels/{channelId} {
      allow read: if isLeaderOrAbove(resource.data.createdByTeamId) ||
        isLeaderOrAboveInTeamList(resource.data.get('memberTeamIds', [])) ||
        isLeaderOrAboveInTeamList(resource.data.get('pendingTeamIds', []));
      allow create: if request.auth != null &&
        request.resource.data.createdByTeamId != null &&
        isLeaderOrAbove(request.resource.data.createdByTeamId);
      allow update: if isPlatformAdmin() ||
        isLeaderOrAbove(resource.data.createdByTeamId) ||
        (
          isLeaderOrAboveInTeamList(resource.data.get('pendingTeamIds', [])) &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['memberTeamIds', 'pendingTeamIds', 'declinedTeamIds', 'updatedAt'])
        ) ||
        (
          isLeaderOrAboveInTeamList(resource.data.get('memberTeamIds', [])) &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['memberTeamIds', 'updatedAt'])
        ) ||
        (
          isLeaderOrAboveInTeamList(resource.data.get('memberTeamIds', [])) &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['lastMessageAt', 'updatedAt'])
        );
      allow delete: if isPlatformAdmin() || isLeaderOrAbove(resource.data.createdByTeamId);
    }

    match /crossTeamChannelTeams/{channelTeamId} {
      allow read: if isPlatformAdmin() ||
        isLeaderOrAbove(resource.data.teamId) ||
        (
          channelExists(resource.data.channelId) &&
          isLeaderOrAboveInTeamList(channelDoc(resource.data.channelId).data.get('memberTeamIds', []))
        );
      allow create: if request.auth != null &&
        request.resource.data.ownerTeamId != null &&
        request.resource.data.teamId != null &&
        isLeaderOrAbove(request.resource.data.ownerTeamId);
      allow update: if isPlatformAdmin() ||
        (
          isLeaderOrAbove(resource.data.ownerTeamId) &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'channelName',
            'channelDescription',
            'status',
            'invitedByMembershipId',
            'invitedByMembershipName',
            'invitedAt',
            'respondedAt',
            'respondedByMembershipId',
            'updatedAt'
          ])
        ) ||
        (
          isLeaderOrAbove(resource.data.teamId) &&
          request.resource.data.teamId == resource.data.teamId &&
          request.resource.data.channelId == resource.data.channelId &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'respondedAt', 'respondedByMembershipId', 'updatedAt'])
        );
      allow delete: if isPlatformAdmin() || isLeaderOrAbove(resource.data.ownerTeamId);
    }

    match /crossTeamMessages/{messageId} {
      allow read: if request.auth != null &&
        resource.data.channelId != null &&
        exists(/databases/$(database)/documents/crossTeamChannels/$(resource.data.channelId)) &&
        isLeaderOrAboveInTeamList(
          get(/databases/$(database)/documents/crossTeamChannels/$(resource.data.channelId)).data.get('memberTeamIds', [])
        );
      allow create: if request.auth != null &&
        request.resource.data.channelId != null &&
        request.resource.data.teamId != null &&
        exists(/databases/$(database)/documents/crossTeamChannels/$(request.resource.data.channelId)) &&
        isLeaderOrAbove(request.resource.data.teamId) &&
        (
          (
            channelTeamExists(request.resource.data.channelId, request.resource.data.teamId) &&
            channelTeamDoc(request.resource.data.channelId, request.resource.data.teamId).data.status in ['owner', 'member']
          ) ||
          get(/databases/$(database)/documents/crossTeamChannels/$(request.resource.data.channelId)).data.get('memberTeamIds', []).hasAny([request.resource.data.teamId])
        );
      allow update, delete: if false;
    }

    match /auditLog/{logId} {
      allow read: if isTeamAdmin(resource.data.teamId);
      allow create: if isLeaderOrAbove(request.resource.data.teamId);
      allow update, delete: if false;
    }

  }
}
